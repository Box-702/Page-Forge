{
  "name": "page-forge",
  "private": true,
  "version": "0.1.0",
  "description": "A Vue 3 visual landing page builder with drag sorting, nested rows, local persistence, undo/redo and static HTML export.",
  "type": "module",
  "homepage": "https://box-702.github.io/Page-Forge/",
  "repository": {
    "type": "git",
    "url": "https://github.com/Box-702/Page-Forge.git"
  },
  "keywords": [
    "vue",
    "typescript",
    "landing-page-builder",
    "page-builder",
    "pinia",
    "sortablejs",
    "tailwindcss"
  ],
  "scripts": {
    "dev": "concurrently -n web,server -c cyan,magenta \"npm:dev:web\" \"npm:dev:server\"",
    "dev:web": "vite",
    "dev:server": "npm --prefix server run dev",
    "build": "vue-tsc -b && vite build",
    "build:server": "npm --prefix server run build",
    "build:all": "npm run build:server && npm run build",
    "typecheck": "vue-tsc -b",
    "typecheck:server": "npm --prefix server run typecheck",
    "typecheck:all": "npm run typecheck && npm run typecheck:server",
    "preview": "vite preview",
    "start:server": "npm --prefix server run start",
    "smoke": "node scripts/smoke.mjs",
    "check": "npm run build && npm run smoke"
  },
  "dependencies": {
    "pinia": "^2.1.7",
    "sortablejs": "^1.15.2",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@types/sortablejs": "^1.15.8",
    "@vitejs/plugin-vue": "^5.0.4",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "~5.4.0",
    "vite": "^5.2.0",
    "vue-tsc": "^2.0.6"
  }
}
